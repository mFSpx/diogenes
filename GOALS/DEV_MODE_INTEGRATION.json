{
  "canonical_graph_writes_performed": false,
  "model_calls_performed_by_checkers": false,
  "no_doc_sprawl_rule": "GOALS owns dev-mode/chain/telemetry authority; receipts stay in 05_OUTPUTS; runtime temp state stays in 04_RUNTIME.",
  "schema": "lucidota.goals.dev_mode_integration.v1",
  "single_owner": "GOALS",
  "status_ledger_sections": [
    "software",
    "hardware_runtime_targets",
    "phases",
    "plans_workstreams"
  ],
  "subsystems": [
    {
      "check": "python3 scripts/goal_handoff.py --root GOALS check",
      "entry": "GOALS/CURRENT_HANDOFF.md",
      "name": "goals_handoff"
    },
    {
      "check": "python3 scripts/goal_dev_control.py --away-minutes 0 --text recovery",
      "entry": "GOALS/AGENT_ORCHESTRATION_POLICY.md",
      "name": "agent_orchestration"
    },
    {
      "check": "python3 scripts/goal_model_fabric_control.py status",
      "entry": "GOALS/MODEL_FABRIC_AUDIT.md",
      "name": "model_fabric"
    },
    {
      "check": "python3 scripts/model_runner_cli.py groq-chat --prompt ping --max-tokens 8 --json && python3 scripts/model_runner_cli.py cohere-chat --prompt ping --max-tokens 8 --json",
      "entry": "GOALS/plugin_build_mode_bootstrap.json",
      "name": "cloud_adapters"
    },
    {
      "check": "python3 scripts/lucidota_status_ledger.py --check && python3 scripts/recovery_matrix.py",
      "entry": "00_PROJECT_BRAIN/STATUS_LEDGER.md",
      "name": "status_recovery"
    },
    {
      "check": "python3 scripts/slop_audit_law.py --paths scripts/goal_handoff.py scripts/goal_dev_control.py scripts/goal_model_fabric_control.py scripts/goal_chain.py scripts/goal_system_index.py scripts/goal_telemetry.py scripts/recovery_matrix.py",
      "entry": "GOALS/DEV_MODE_FEATURE_AUDIT.json",
      "name": "slop_control"
    },
    {
      "check": "python3 scripts/goal_chain.py check",
      "entry": "GOALS/NEXT_GOAL_QUEUE.json",
      "name": "goal_chain"
    },
    {
      "check": "python3 scripts/goal_system_index.py",
      "entry": "05_OUTPUTS/goals/system_function_index_latest.json",
      "name": "system_function_index"
    },
    {
      "check": "python3 scripts/goal_telemetry.py snapshot",
      "entry": "scripts/goal_telemetry.py",
      "name": "goal_telemetry"
    },
    {
      "check": "python3 scripts/no_delete_guard.py check",
      "entry": "GOALS/NO_DELETE_BASELINE.json",
      "name": "no_delete_guard"
    },
    {
      "check": "python3 scripts/language_router.py --text \"fix code prove it\" --json",
      "entry": "scripts/language_router.py",
      "name": "language_router"
    },
    {
      "check": "python3 scripts/lucidota_cli.py language --text recovery --json >/dev/null && python3 scripts/language_router.py --text recovery --json >/dev/null",
      "entry": "scripts/lucidota_cli.py language",
      "name": "language_subsystem"
    },
    {
      "check": "python3 scripts/goal_agent_packet.py --target generic --task recovery --complexity simple --json >/dev/null",
      "entry": "scripts/goal_agent_packet.py",
      "name": "agent_packet_exporter"
    },
    {
      "check": "python3 scripts/goal_swarm_dispatch.py --target generic --task recovery --jobs 1 --json >/dev/null",
      "entry": "scripts/goal_swarm_dispatch.py",
      "name": "goal_swarm_dispatch"
    }
  ]
}
