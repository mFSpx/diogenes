#!/usr/bin/env bash
set -euo pipefail
ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
CLAW="$ROOT/01_REPOS/claudecode/rust/target/release/claw"
cd "$ROOT"
clear || true
printf '\n=== LUCIDOTA LAUNCH DEMO ===\n\n'
printf '1) Build bars\n'
"$CLAW" lucidota-status | sed -n '1,28p'
printf '\n2) Cockpit\n'
"$CLAW" cockpit | sed -n '1,80p'
printf '\n3) Kernel API bridge\n'
"$CLAW" diogenes-smoke | sed -n '1,80p'
printf '\n4) Model readiness\n'
.venv/bin/python -c 'import json,subprocess; j=json.loads(subprocess.check_output([".venv/bin/python","scripts/lucidota_model_artifact_readiness.py","--json"])); print("routing_registry_ready:", j["routing_registry_ready"]); print("all_requested_artifacts_present:", j["artifact_ready"]); print("demo_inference_artifact_ready:", j.get("demo_inference_artifact_ready")); print("zero_refusal_guarantee:", j["zero_refusal_guarantee"]); print("usable_weight_files:"); [print(" -", x["path"], x["bytes"]) for x in j["usable_weight_files"][:10]]'
printf '\n5) Live servers\n'
for port in 8080 8081 8090 8091 8092 8093 8094 8095 8088; do
  printf ':%s ' "$port"
  curl -fsS "http://127.0.0.1:$port/health" 2>/dev/null | head -c 160 || curl -fsS "http://127.0.0.1:$port/v1/models" 2>/dev/null | head -c 160 || echo -n DOWN
  echo
 done
printf '\n=== READY ===\n'
